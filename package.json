{
  "name": "shell-gems",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "npm-run-all --parallel build:angular:watch build:main:watch wait:electron",
    "build:angular": "cd renderer && npm run build",
    "build:angular:watch": "cd renderer && npm run watch",
    "build:main": "tsc",
    "build:main:watch": "tsc -w",
    "wait:electron": "wait-on renderer/dist/renderer/browser/index.html && electron .",
    "build:portable": "npm run build:angular && npm run build:main && node scripts/build.js"
  },
  "keywords": [],
  "author": "Shell-Gems",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-packager": "^17.1.2",
    "fs-extra": "^11.3.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "electron-edge-js": "^40.0.1"
  }
}